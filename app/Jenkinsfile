pipeline {

    agent any

    stages {
	stage('SonarQube Scan') {
 	   steps {
        	dir('app') {
            	script {
                	def scannerHome = tool 'sonar-scanner'

                	withSonarQubeEnv('sonarqube') {
                   	 sh "${scannerHome}/bin/sonar-scanner"
               	 }
            }
        }
    }
}
        stage('Build Docker Image') {
            steps {
                dir('app') {
                    sh 'docker build -t flask-demo:v1 .'
                }
            }
        }

        stage('Verify Image') {
            steps {
                sh 'docker images | grep flask-demo'
            }
        }
    }
}
